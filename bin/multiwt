#!/usr/bin/env bash
set -Eeuo pipefail

# Resolve this script through any symlinks so lib/ is found even when
# `multiwt` is installed as a symlink on $PATH (e.g. ~/.local/bin/multiwt).
MULTIWT_SRC="${BASH_SOURCE[0]}"
while [[ -h "$MULTIWT_SRC" ]]; do
  MULTIWT_DIR="$(cd -P "$(dirname "$MULTIWT_SRC")" && pwd)"
  MULTIWT_SRC="$(readlink "$MULTIWT_SRC")"
  [[ "$MULTIWT_SRC" != /* ]] && MULTIWT_SRC="$MULTIWT_DIR/$MULTIWT_SRC"
done
MULTIWT_BIN="$(cd -P "$(dirname "$MULTIWT_SRC")" && pwd)/$(basename "$MULTIWT_SRC")"
MULTIWT_ROOT="$(cd -P "$(dirname "$MULTIWT_BIN")/.." && pwd)"
MULTIWT_LIB="$MULTIWT_ROOT/lib"

# shellcheck source=../lib/common.sh
. "$MULTIWT_LIB/common.sh"
# shellcheck source=../lib/config.sh
. "$MULTIWT_LIB/config.sh"
# shellcheck source=../lib/git.sh
. "$MULTIWT_LIB/git.sh"
# shellcheck source=../lib/tmux.sh
. "$MULTIWT_LIB/tmux.sh"

usage() {
  cat <<EOF
Usage:
  multiwt up <name> [--from <ref>] [--no-attach] [--no-install]
  multiwt rm <name|path> [--purge] [--force]
  multiwt ls
  multiwt sync [--all]
  multiwt status
  multiwt exec <cmd>
  multiwt cd <name>
  multiwt register [--name <slug>] [--refresh]

Global flags:
  --verbose          Verbose logging
  -h, --help         Show this help
EOF
}

main() {
  # Global flags may appear before the subcommand.
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --verbose) MULTIWT_VERBOSE=1; shift ;;
      *) break ;;
    esac
  done

  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    -h|--help|"") usage; [[ -z "$cmd" ]] && exit 1 || exit 0 ;;
    up)       . "$MULTIWT_LIB/up.sh"       && cmd_up       "$@" ;;
    rm)       . "$MULTIWT_LIB/rm.sh"       && cmd_rm       "$@" ;;
    ls)       . "$MULTIWT_LIB/ls.sh"       && cmd_ls       "$@" ;;
    sync)     . "$MULTIWT_LIB/sync.sh"     && cmd_sync     "$@" ;;
    status)   . "$MULTIWT_LIB/status.sh"   && cmd_status   "$@" ;;
    exec)     . "$MULTIWT_LIB/exec.sh"     && cmd_exec     "$@" ;;
    cd)       . "$MULTIWT_LIB/cd.sh"       && cmd_cd       "$@" ;;
    register) . "$MULTIWT_LIB/register.sh" && cmd_register "$@" ;;
    *) err "Unknown command: $cmd"; usage; exit 1 ;;
  esac
}
main "$@"
